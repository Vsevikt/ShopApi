{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.; Database=BaseStore; Integrated Security=True; TrustServerCertificate=True;"
  },
  "DirnameForFiles": {
    "Categories": "categories",
    "Products": "products"
  },
  "FileSettings": {
    "MaxProductImages": 12,
    "MaxFileSizeMb": 5,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".webp"]
  }
}
